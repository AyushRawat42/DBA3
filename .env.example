# Canonical environment variables for Aspire Academy admissions.
# Copy to .env.local for local development.
#
# Legacy aliases still supported (use if your host already sets them):
# DDB_TABLE_MAIN
# APP_AWS_REGION
# APP_AWS_ACCESS_KEY_ID
# APP_AWS_SECRET_ACCESS_KEY
#
# Production notes:
# - NODE_ENV is set by the host (do not set manually on Vercel).
# - Admin login requires HTTPS in production (secure session cookies).
# - ADMIN_EMAIL, ADMIN_PASSWORD_HASH (or BASE64), and ADMIN_SESSION_SECRET are required in production.
# - Do not rely on dev defaults for ADMIN_EMAIL or session signing in production.
# - On Vercel/Amplify serverless: AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY are required.
# - On EC2/ECS/Docker with an IAM instance/task role: AWS keys may be omitted.

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD_HASH_BASE64=
ADMIN_SESSION_SECRET=

ADMISSIONS_TABLE_NAME=AspireAdmissions
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
